{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "EarnFi Docs",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": {
    "light": "/favicon.svg",
    "dark": "/favicon.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "getting-started/connect-wallet",
              "getting-started/profile"
            ]
          },
          {
            "group": "Earn",
            "pages": [
              "earn/jobs-feed",
              "earn/submit-work",
              "earn/pending",
              "earn/earnings",
              "earn/withdrawals",
              "earn/referrals"
            ]
          }
        ]
      },
      {
        "tab": "Creators",
        "groups": [
          {
            "group": "Creator hub",
            "pages": [
              "creators/overview",
              "creators/jobs",
              "creators/disputes",
              "creators/verifications",
              "creators/payments"
            ]
          }
        ]
      },
      {
        "tab": "Tools",
        "groups": [
          {
            "group": "Utilities",
            "pages": [
              "tools/recover-sol",
              "tools/burn-vault",
              "tools/contests"
            ]
          }
        ]
      },
      {
        "tab": "Safety",
        "groups": [
          {
            "group": "Account & verification",
            "pages": [
              "safety/x-verification",
              "safety/restrictions",
              "safety/safety-notices"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://earnfi.fun"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@earnfi.fun"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open EarnFi",
      "href": "https://earnfi.fun"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/earnfidotfun",
      "github": "https://github.com/earnfidotfun"
    }
  },
  "background": {
    "color": {
      "dark": "#030610",
      "light": "#f7f7f7"
    }
  },
  "appearance": {
    "default": "system"
  }
}
